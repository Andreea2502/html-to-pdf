{
  "name": "html-to-pdf-designer",
  "version": "1.0.0",
  "description": "Konvertiert HTML in hochwertig designte PDF-Dokumente (Whitepaper, E-Book, Zertifikat-Style, Lebensläufe) mit Puppeteer. Lokale CLI + Web-UI für Vercel.",
  "type": "module",
  "bin": {
    "html2pdf": "./src/cli.js"
  },
  "scripts": {
    "cli:whitepaper": "node src/cli.js --input examples/whitepaper.html --output out/whitepaper.pdf",
    "cli:certificate": "node src/cli.js --input examples/certificate.html --output out/certificate.pdf --landscape",
    "dev": "vercel dev",
    "deploy": "vercel --prod"
  },
  "dependencies": {
    "@sparticuz/chromium": "^131.0.1",
    "commander": "^12.1.0",
    "handlebars": "^4.7.8",
    "puppeteer": "^23.0.0",
    "puppeteer-core": "^23.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
